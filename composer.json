{
    "name": "jeffersongoncalves/laravel-zero-api-client",
    "description": "Reusable base REST HTTP client for Laravel Zero CLIs: get/post/put/delete, pagination, Basic/Bearer auth and consistent API error handling.",
    "keywords": ["laravel-zero", "cli", "http", "rest", "api-client", "guzzle"],
    "homepage": "https://github.com/jeffersongoncalves/laravel-zero-api-client",
    "license": "MIT",
    "authors": [
        { "name": "Jefferson Goncalves", "email": "jeffersongoncalves@users.noreply.github.com" }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.10"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.8|^4.1",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": { "JeffersonGoncalves\\LaravelZero\\ApiClient\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "JeffersonGoncalves\\LaravelZero\\ApiClient\\Tests\\": "tests/" }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse",
        "test:unit": "pest",
        "test": ["@test:unit", "@test:lint"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "pestphp/pest-plugin": true }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
